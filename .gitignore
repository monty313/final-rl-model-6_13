!tests/**/*.csv

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
.venv/
venv/
env/
.python-version

# --- Tooling / caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.optuna/
# optuna study sqlite:
*.db

# --- OS / editor / agent ---
.DS_Store
Thumbs.db
.vscode/
.idea/
