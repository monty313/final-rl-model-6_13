# --- Quantra data + artifacts (never committed; large + run-specific) ---
data/
artifacts/
*.parquet
*.npy
*.memmap
*.csv
# tiny fixture CSVs for unit tests are allowed:
!tests/**/*.csv
# Barbershop runtime telemetry inputs + exports (generated, not source):
logs/
models/

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.egg-info/
.eggs/
build/
dist/
# Anchor virtualenv dirs to the repo ROOT so they don't match the quantra/env/
# package (a bare `env/` matches at any depth and silently ignored the env module).
.venv/
/venv/
/env/
.python-version

# --- Tooling / caches ---
.pytest_cache/
.mypy_cache/
.ruff_cache/
.ipynb_checkpoints/
.optuna/
# optuna study sqlite:
*.db

# --- OS / editor / agent ---
.DS_Store
Thumbs.db
.vscode/
.idea/
# local Claude Code session settings, not project code:
.claude/
plan.md

# --- Secrets (never commit broker creds / tokens) ---
.env
*.key
mt5_credentials.*
